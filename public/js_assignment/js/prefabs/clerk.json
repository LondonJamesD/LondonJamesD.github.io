{
    "id":"clerk",
    "special":"yes",
    "states":[
        {
            "stateID":"normal",
            "stuck":"yes",
            "imgPath":"clerk.png",
            "children":[],
            "examine":"'man I'm thirsty for some cola...'"
        },
        {
            "stateID":"cola",
            "stuck":"yes",
            "imgPath":"clerk_cola.png",
            "children":[],
            "examine":"'yummy...'",
            "entryAction":"setFlag(clerkHasCola)"
        },
        {
            "stateID":"sleep",
            "stuck":"yes",
            "imgPath":"clerk_sleep.gif",
            "children":[],
            "examine":"'zzzz'",
            "entryAction":["setFlag(clerkAsleep)", "addProgress"]
        }
    ],
    "clickAction":"justExamine",
    "ignoreState":"no",
    "itemInteractions": {
        "cola": {
            "action": "forceState(1)",
            "consumeItem": true
        },
        "sleepingPills":{
            "action":"conditional(clerkHasCola, forceState, 2)",
            "consumeItem":true
        }
    }
}